{
  "name": "hos-scrcpy",
  "version": "1.1.1",
  "description": "HarmonyOS screen casting server - TypeScript replacement for demoWithoutRecord.jar",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hos-scrcpy": "dist/bin/server.js"
  },
  "files": [
    "dist/",
    "templates/"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "clean": "node scripts/clean.js",
    "start": "node dist/bin/server.js",
    "ui": "node scripts/start-ui.js",
    "dev": "ts-node src/bin/server.ts",
    "pack": "npm run build && node scripts/pack.js",
    "prepublishOnly": "npm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:unit": "vitest run --dir test/unit",
    "test:integration": "vitest run --dir test/integration",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test --config test/e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config test/e2e/playwright.config.ts --headed",
    "test:e2e:debug": "npx playwright test --config test/e2e/playwright.config.ts --debug"
  },
  "keywords": [
    "harmonyos",
    "scrcpy",
    "screen-cast",
    "hdc",
    "screen-mirroring",
    "huawei"
  ],
  "author": "Yonglun Yao <yonglunyao@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yonglunyao/hos-scrcpy"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "@types/node-fetch": "^2.6.13",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.3.3",
    "vitest": "^4.1.2"
  }
}
